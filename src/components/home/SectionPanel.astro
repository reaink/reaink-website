---
import { iconMap, type IconName } from "@/lib/icons";

interface Props {
  title: string;
  icon: IconName;
  href?: string;
  linkLabel?: string;
  external?: boolean;
}

const { title, icon, href, linkLabel, external = false } = Astro.props;

const Icon = iconMap[icon];
---

<section
  class="rounded-[1.9rem] border border-white/65 bg-white/52 p-4 shadow-[0_18px_60px_rgba(15,23,42,0.05)] backdrop-blur-xl dark:border-white/10 dark:bg-slate-950/48 dark:shadow-[0_24px_70px_rgba(2,6,23,0.45)] sm:p-7"
>
  <div
    class="mb-4 flex flex-col items-start justify-between gap-2 sm:flex-row sm:items-center"
  >
    <h2
      class="flex items-center gap-2 text-sm font-semibold text-muted-foreground"
    >
      <Icon className="h-4 w-4" />
      {title}
    </h2>
    {
      href && linkLabel && (
        <a
          href={href}
          target={external ? "_blank" : undefined}
          rel={external ? "noopener noreferrer" : undefined}
          class="text-xs text-muted-foreground transition-colors hover:text-foreground"
        >
          {linkLabel}
        </a>
      )
    }
  </div>
  <slot />
</section>

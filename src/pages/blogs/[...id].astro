---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import { getCategoryHref, getTagHref } from "@/lib/home";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} · Reaink`} showPageview={true}>
  <article class="prose prose-neutral dark:prose-invert max-w-none">
    <header class="not-prose mb-8">
      <div class="flex flex-wrap gap-2 mb-3">
        {
          post.data.categories.map((cat) => (
            <a
              href={getCategoryHref(cat)}
              class="rounded-full bg-primary/10 px-3 py-0.5 text-xs text-primary transition-colors hover:bg-primary/16"
            >
              {cat}
            </a>
          ))
        }
      </div>
      <h1 class="text-3xl font-bold tracking-tight mb-3">{post.data.title}</h1>
      <div class="flex items-center gap-4 text-sm text-muted-foreground">
        {
          post.data.date && (
            <time>
              {new Date(post.data.date).toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          )
        }
        <div class="flex flex-wrap items-center gap-1.5">
          {
            post.data.tags.map((tag) => (
              <a
                href={getTagHref(tag)}
                class="rounded-full px-1.5 py-0.5 text-muted-foreground transition-colors hover:bg-primary/8 hover:text-primary"
              >
                #{tag}
              </a>
            ))
          }
        </div>
      </div>
    </header>
    <Content />
  </article>

  <div class="mt-12 pt-6 border-t border-border">
    <a
      href="/blogs"
      class="text-sm text-muted-foreground hover:text-foreground transition-colors"
      >← 返回博客列表</a
    >
  </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import ResumeActions from "@/components/resume/ResumeActions";
import { iconMap } from "@/lib/icons";
import { resumeData } from "@/lib/resume";

const contactItems = resumeData.contacts.map((item) => ({
  ...item,
  Icon: iconMap[item.icon],
}));

const skillGroups = resumeData.skillGroups.map((group) => ({
  ...group,
  Icon: iconMap[group.icon],
}));
---

<Layout
  title={resumeData.seo.title}
  description={resumeData.seo.description}
  robots="noindex, nofollow, noarchive, nosnippet, noimageindex"
  wide={true}
  pageBackdrop={true}
>
  <div class="resume-page space-y-5">
    <section
      class="resume-tools print:hidden rounded-[1.8rem] border border-white/65 bg-white/58 p-4 shadow-[0_22px_60px_rgba(15,23,42,0.05)] backdrop-blur-xl dark:border-white/10 dark:bg-slate-950/50 dark:shadow-[0_24px_70px_rgba(2,6,23,0.45)] sm:p-5"
    >
      <div
        class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between"
      >
        <div class="space-y-2">
          <div
            class="inline-flex items-center gap-2 rounded-full border border-black/6 bg-white/78 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.22em] text-muted-foreground dark:border-white/10 dark:bg-white/8"
          >
            Resume / Structured JSON
          </div>
          <div>
            <h1
              class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl"
            >
              在线简历
            </h1>
          </div>
        </div>
        <ResumeActions client:only="react" />
      </div>
    </section>

    <article
      id="resume-document"
      class="resume-document rounded-[2rem] border border-white/70 bg-white/72 p-5 shadow-[0_28px_90px_rgba(15,23,42,0.08)] backdrop-blur-2xl dark:border-white/10 dark:bg-slate-950/62 dark:shadow-[0_28px_90px_rgba(2,6,23,0.52)] sm:p-8"
    >
      <section
        class="resume-card resume-hero resume-avoid-break mb-5 overflow-hidden rounded-[1.8rem] border border-black/6 bg-linear-to-br from-white via-white to-slate-100/70 p-6 dark:border-white/10 dark:from-slate-950 dark:via-slate-950 dark:to-slate-900 sm:p-7"
      >
        <div
          class="resume-hero-grid grid gap-6 xl:grid-cols-[1.35fr_0.9fr] xl:items-end"
        >
          <div>
            <div
              class="inline-flex items-center gap-2 rounded-full bg-[#6b6cff]/10 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.24em] text-[#4f46e5] dark:bg-[#6b6cff]/16 dark:text-[#a5b4fc]"
            >
              {resumeData.basics.experience} Experience
            </div>
            <h1
              class="mt-4 text-4xl font-bold tracking-[-0.04em] text-foreground sm:text-5xl"
            >
              {resumeData.basics.name}
            </h1>
            <p
              class="mt-3 text-lg font-medium text-slate-600 dark:text-slate-300"
            >
              {resumeData.basics.title}
            </p>
            <p
              class="mt-4 max-w-3xl text-sm leading-7 text-slate-600 dark:text-slate-300 sm:text-[15px]"
            >
              {resumeData.basics.summary}
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              {
                resumeData.basics.focus.map((item) => (
                  <span class="rounded-full border border-black/6 bg-white/80 px-3 py-1.5 text-xs font-medium text-foreground dark:border-white/10 dark:bg-white/8 dark:text-slate-100">
                    {item}
                  </span>
                ))
              }
            </div>
          </div>

          <div class="resume-stats-grid grid gap-3 sm:grid-cols-3">
            {
              resumeData.stats.map((stat) => (
                <div class="resume-avoid-break rounded-[1.35rem] border border-black/6 bg-white/84 p-4 dark:border-white/10 dark:bg-white/8">
                  <div class="text-xs font-medium uppercase tracking-[0.22em] text-muted-foreground">
                    {stat.label}
                  </div>
                  <div class="mt-3 text-2xl font-semibold tracking-tight text-foreground">
                    {stat.value}
                  </div>
                  <p class="mt-2 text-xs leading-5 text-slate-500 dark:text-slate-300">
                    {stat.hint}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <div class="resume-layout grid gap-5 xl:grid-cols-[0.88fr_1.32fr]">
        <aside class="resume-sidebar space-y-5">
          <section
            class="resume-card resume-avoid-break rounded-[1.7rem] border border-black/6 bg-white/78 p-5 dark:border-white/10 dark:bg-white/6"
          >
            <div class="mb-4 flex items-center justify-between gap-3">
              <h2
                class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
              >
                联系方式
              </h2>
              <span class="text-xs text-muted-foreground"
                >{resumeData.basics.location}</span
              >
            </div>
            <div class="resume-contacts-grid grid gap-3 sm:grid-cols-2">
              {
                contactItems.map(({ label, value, href, Icon }) =>
                  href ? (
                    <a
                      href={href}
                      target={href.startsWith("http") ? "_blank" : undefined}
                      rel={
                        href.startsWith("http")
                          ? "noopener noreferrer"
                          : undefined
                      }
                      class="group flex min-w-0 items-center gap-3 rounded-[1.2rem] border border-black/6 bg-white/78 px-4 py-3 transition-all hover:-translate-y-0.5 hover:border-black/10 hover:bg-white dark:border-white/10 dark:bg-white/6 dark:hover:bg-white/10"
                    >
                      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[#6b6cff]/10 text-[#4f46e5] dark:bg-[#6b6cff]/16 dark:text-[#a5b4fc]">
                        <Icon className="h-4 w-4" />
                      </div>
                      <div class="min-w-0">
                        <div class="text-xs text-muted-foreground">{label}</div>
                        <div class="break-all text-sm font-medium text-foreground">
                          {value}
                        </div>
                      </div>
                    </a>
                  ) : (
                    <div class="flex min-w-0 items-center gap-3 rounded-[1.2rem] border border-black/6 bg-white/78 px-4 py-3 dark:border-white/10 dark:bg-white/6">
                      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-[#6b6cff]/10 text-[#4f46e5] dark:bg-[#6b6cff]/16 dark:text-[#a5b4fc]">
                        <Icon className="h-4 w-4" />
                      </div>
                      <div class="min-w-0">
                        <div class="text-xs text-muted-foreground">{label}</div>
                        <div class="break-all text-sm font-medium text-foreground">
                          {value}
                        </div>
                      </div>
                    </div>
                  ),
                )
              }
            </div>
          </section>

          <section
            class="resume-card rounded-[1.7rem] border border-black/6 bg-white/78 p-5 dark:border-white/10 dark:bg-white/6"
          >
            <div class="mb-4 flex items-center gap-2">
              <div class="h-2.5 w-2.5 rounded-full bg-[#6b6cff]"></div>
              <h2
                class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
              >
                技能栈
              </h2>
            </div>
            <div class="grid gap-4">
              {
                skillGroups.map(({ title, items, Icon }) => (
                  <div class="resume-avoid-break rounded-[1.35rem] border border-black/6 bg-white/76 p-4 dark:border-white/10 dark:bg-white/6">
                    <div class="flex items-center gap-2 text-sm font-semibold text-foreground">
                      <Icon className="h-4 w-4 text-muted-foreground" />
                      {title}
                    </div>
                    <div class="mt-3 flex flex-wrap gap-2">
                      {items.map((item) => (
                        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs text-slate-700 dark:bg-slate-800 dark:text-slate-200">
                          {item}
                        </span>
                      ))}
                    </div>
                  </div>
                ))
              }
            </div>
          </section>

          <section
            class="resume-card resume-avoid-break rounded-[1.7rem] border border-black/6 bg-white/78 p-5 dark:border-white/10 dark:bg-white/6"
          >
            <h2
              class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
            >
              教育与补充
            </h2>
            <div class="mt-4 space-y-4">
              {
                resumeData.education.map((item) => (
                  <div>
                    <div class="text-base font-semibold text-foreground">
                      {item.school}
                    </div>
                    <div class="mt-1 text-sm text-muted-foreground">
                      {item.period}
                    </div>
                  </div>
                ))
              }
              <div class="h-px bg-black/6 dark:bg-white/10"></div>
              <ul
                class="space-y-2 text-sm leading-7 text-slate-600 dark:text-slate-300"
              >
                {
                  resumeData.extras.map((item) => (
                    <li class="flex gap-2">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#6b6cff]" />
                      <span>{item}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </section>
        </aside>

        <div class="resume-main space-y-5">
          <section
            class="resume-card rounded-[1.7rem] border border-black/6 bg-white/78 p-5 dark:border-white/10 dark:bg-white/6"
          >
            <div class="mb-5 flex items-center justify-between gap-3">
              <h2
                class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
              >
                工作经历
              </h2>
              <span class="text-xs text-muted-foreground">按时间倒序</span>
            </div>
            <div class="space-y-4">
              {
                resumeData.experienceItems.map((item) => (
                  <article class="resume-entry resume-avoid-break rounded-[1.5rem] border border-black/6 bg-white/82 p-5 dark:border-white/10 dark:bg-white/6">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <h3 class="text-xl font-semibold tracking-tight text-foreground">
                          {item.company}
                        </h3>
                        <p class="mt-1 text-sm text-muted-foreground">
                          {item.team}
                        </p>
                      </div>
                      <div class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-200">
                        {item.period}
                      </div>
                    </div>
                    <p class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-300">
                      {item.summary}
                    </p>
                    <ul class="mt-4 space-y-2 text-sm leading-7 text-slate-700 dark:text-slate-200">
                      {item.highlights.map((highlight) => (
                        <li class="flex gap-2">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#6b6cff]" />
                          <span>{highlight}</span>
                        </li>
                      ))}
                    </ul>
                    <div class="mt-4 flex flex-wrap gap-2">
                      {item.stack.map((stack) => (
                        <span class="rounded-full border border-black/6 bg-white/88 px-2.5 py-1 text-xs text-slate-700 dark:border-white/10 dark:bg-slate-900/80 dark:text-slate-200">
                          {stack}
                        </span>
                      ))}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>

          <section
            class="resume-card rounded-[1.7rem] border border-black/6 bg-white/78 p-5 dark:border-white/10 dark:bg-white/6"
          >
            <div class="mb-5 flex items-center justify-between gap-3">
              <h2
                class="text-sm font-semibold uppercase tracking-[0.2em] text-muted-foreground"
              >
                开源项目
              </h2>
              <span class="text-xs text-muted-foreground"
                >持续维护而不是一次性展示</span
              >
            </div>
            <div class="grid gap-4 lg:grid-cols-2">
              {
                resumeData.projects.map((project) => (
                  <article class="resume-entry resume-avoid-break flex h-full flex-col rounded-[1.5rem] border border-black/6 bg-white/82 p-5 dark:border-white/10 dark:bg-white/6">
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <h3 class="text-xl font-semibold tracking-tight text-foreground">
                          {project.name}
                        </h3>
                        <p class="mt-1 text-sm text-muted-foreground">
                          {project.period}
                        </p>
                      </div>
                    </div>
                    <p class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-300">
                      {project.summary}
                    </p>
                    <ul class="mt-4 space-y-2 text-sm leading-7 text-slate-700 dark:text-slate-200">
                      {project.bullets.map((bullet) => (
                        <li class="flex gap-2">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[#14b8a6]" />
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>
                    <div class="mt-4 flex flex-wrap gap-2">
                      {project.tags.map((tag) => (
                        <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-200">
                          {tag}
                        </span>
                      ))}
                    </div>
                    <div class="mt-5 flex flex-wrap gap-3 text-sm">
                      {project.links.map((link) => (
                        <a
                          href={link.href}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-medium text-foreground underline decoration-black/15 underline-offset-4 transition-colors hover:text-[#4f46e5] dark:decoration-white/20 dark:hover:text-[#a5b4fc]"
                        >
                          {link.label}
                        </a>
                      ))}
                    </div>
                  </article>
                ))
              }
            </div>
          </section>
        </div>
      </div>
    </article>
  </div>

  <style is:global>
    @media print {
      @page {
        size: A4;
        margin: 8mm;
      }

      html,
      body {
        background: #ffffff !important;
        font-size: 13px !important;
      }

      header,
      footer,
      .resume-tools {
        display: none !important;
      }

      main {
        max-width: none !important;
        padding: 0 !important;
      }

      .resume-page,
      .resume-document,
      .resume-card {
        margin: 0 !important;
        background: #ffffff !important;
        border-color: rgba(15, 23, 42, 0.12) !important;
        box-shadow: none !important;
        backdrop-filter: none !important;
      }

      .resume-document {
        border: none !important;
        padding: 0 !important;
      }

      .resume-page > * + * {
        margin-top: 0.5rem !important;
      }

      .resume-hero,
      .resume-card,
      .resume-entry {
        border-radius: 1rem !important;
        padding: 0.8rem !important;
      }

      .resume-hero {
        margin-bottom: 0.5rem !important;
      }

      .resume-hero-grid,
      .resume-layout {
        gap: 0.6rem !important;
      }

      .resume-layout {
        grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr) !important;
        align-items: start !important;
      }

      .resume-sidebar,
      .resume-main {
        display: flex !important;
        flex-direction: column !important;
        gap: 0.6rem !important;
      }

      .resume-sidebar > *,
      .resume-main > * {
        margin-top: 0 !important;
      }

      .resume-stats-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
      }

      .resume-contacts-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      }

      .resume-document .space-y-5 > * + * {
        margin-top: 0.6rem !important;
      }

      .resume-document .space-y-4 > * + * {
        margin-top: 0.45rem !important;
      }

      .resume-document .space-y-2 > * + * {
        margin-top: 0.3rem !important;
      }

      .resume-document .mb-5 {
        margin-bottom: 0.6rem !important;
      }

      .resume-document .mb-4,
      .resume-document .mt-4,
      .resume-document .mt-5 {
        margin-top: 0.45rem !important;
        margin-bottom: 0.45rem !important;
      }

      .resume-document .mt-3 {
        margin-top: 0.3rem !important;
      }

      .resume-document .mt-2,
      .resume-document .mt-1 {
        margin-top: 0.2rem !important;
      }

      .resume-document p,
      .resume-document li {
        line-height: 1.5 !important;
      }

      .resume-document .text-4xl {
        font-size: 2.2rem !important;
      }

      .resume-document .text-2xl {
        font-size: 1.5rem !important;
      }

      .resume-avoid-break {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      .resume-entry {
        break-inside: auto !important;
        page-break-inside: auto !important;
      }

      .resume-entry > :first-child {
        break-after: avoid;
        page-break-after: avoid;
      }

      .resume-entry ul,
      .resume-entry .flex.flex-wrap {
        break-inside: avoid;
        page-break-inside: avoid;
      }

      a {
        color: inherit !important;
        text-decoration: none !important;
      }
    }
  </style>
</Layout>

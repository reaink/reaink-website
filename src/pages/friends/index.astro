---
import Layout from "../../layouts/Layout.astro";
import SectionPanel from "@/components/home/SectionPanel.astro";
import {
  activeFriends,
  inactiveFriends,
  type FriendLink,
} from "@/data/friends";
import { ExternalLink, Link2 } from "lucide-react";

const getInitials = (name: string) =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("") || name.slice(0, 2).toUpperCase();

const getHostname = (href: string) => {
  try {
    return new URL(href).hostname.replace(/^www\./, "");
  } catch {
    return href;
  }
};

const isSecureImage = (avatar?: string) =>
  Boolean(avatar?.startsWith("https://"));

const getCardClass = (faded = false) =>
  `group flex h-full items-start gap-4 rounded-[1.6rem] border p-4 transition-all hover:-translate-y-1 hover:shadow-[0_24px_56px_rgba(15,23,42,0.08)] dark:hover:shadow-[0_24px_56px_rgba(2,6,23,0.4)] sm:p-5 ${
    faded
      ? "border-black/5 bg-black/2 opacity-72 dark:border-white/10 dark:bg-white/4"
      : "border-black/5 bg-white/78 shadow-[0_18px_48px_rgba(15,23,42,0.05)] dark:border-white/10 dark:bg-slate-950/62"
  }`;
---

<Layout
  title="朋友们 · Reaink"
  description="友情链接推荐与伙伴站点导航"
  wide={true}
  pageBackdrop={true}
>
  <section
    class="relative mb-8 rounded-[2rem] border border-white/65 bg-white/56 p-6 shadow-[0_24px_70px_rgba(15,23,42,0.06)] backdrop-blur-xl dark:border-white/10 dark:bg-slate-950/50 dark:shadow-[0_24px_70px_rgba(2,6,23,0.45)] sm:p-8"
  >
    <div class="flex items-start gap-3">
      <div
        class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-[#6b6cff]/12 text-[#6b6cff]"
      >
        <Link2 className="h-5 w-5" />
      </div>
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">
          朋友们
        </h1>
        <p
          class="mt-3 max-w-3xl text-sm leading-7 text-slate-500 dark:text-slate-300"
        >
          这里汇集好学、上进的伙伴们的个人站点。若你也想交换友链，可以给我留言或发邮件，我看到后会尽快补上。
        </p>
      </div>
    </div>
  </section>

  <div class="grid gap-5 xl:grid-cols-[1.45fr_1fr]">
    <SectionPanel title="常来常往的伙伴" icon="users">
      <div class="grid gap-4 md:grid-cols-2">
        {
          activeFriends.map((friend: FriendLink) => (
            <a
              href={friend.href}
              target="_blank"
              rel="noopener noreferrer"
              class={getCardClass()}
            >
              {isSecureImage(friend.avatar) ? (
                <img
                  src={friend.avatar}
                  alt={`${friend.name} avatar`}
                  class="h-14 w-14 shrink-0 rounded-2xl border border-black/6 bg-white object-cover p-1 dark:border-white/10 dark:bg-slate-900/80 sm:h-16 sm:w-16"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                />
              ) : (
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-linear-to-br from-[#6b6cff] via-[#4f8dfd] to-[#2dd4bf] text-sm font-semibold text-white shadow-[0_16px_36px_rgba(79,141,253,0.28)] sm:h-16 sm:w-16 sm:text-base">
                  {getInitials(friend.name)}
                </div>
              )}
              <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <h2 class="truncate text-base font-semibold text-foreground sm:text-lg">
                      {friend.name}
                    </h2>
                    <p class="mt-1 text-xs text-muted-foreground">
                      {getHostname(friend.href)}
                    </p>
                  </div>
                  <ExternalLink className="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground transition-colors group-hover:text-foreground" />
                </div>
                {friend.bio && (
                  <p class="mt-3 line-clamp-2 text-sm leading-6 text-slate-500 dark:text-slate-300">
                    {friend.bio}
                  </p>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </SectionPanel>

    <SectionPanel title="暂时失效的站点" icon="fileText">
      <div class="grid gap-4">
        {
          inactiveFriends.map((friend: FriendLink) => (
            <a
              href={friend.href}
              target="_blank"
              rel="noopener noreferrer"
              class={getCardClass(true)}
            >
              {isSecureImage(friend.avatar) ? (
                <img
                  src={friend.avatar}
                  alt={`${friend.name} avatar`}
                  class="h-14 w-14 shrink-0 rounded-2xl border border-black/6 bg-white object-cover p-1 dark:border-white/10 dark:bg-slate-900/80 sm:h-16 sm:w-16"
                  loading="lazy"
                  referrerpolicy="no-referrer"
                />
              ) : (
                <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-linear-to-br from-slate-500 via-slate-400 to-slate-300 text-sm font-semibold text-white sm:h-16 sm:w-16 sm:text-base">
                  {getInitials(friend.name)}
                </div>
              )}
              <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <h2 class="truncate text-base font-semibold text-foreground sm:text-lg">
                      {friend.name}
                    </h2>
                    <p class="mt-1 text-xs text-muted-foreground">
                      {getHostname(friend.href)}
                    </p>
                  </div>
                  <ExternalLink className="mt-0.5 h-4 w-4 shrink-0 text-muted-foreground transition-colors group-hover:text-foreground" />
                </div>
                {friend.bio && (
                  <p class="mt-3 line-clamp-2 text-sm leading-6 text-slate-500 dark:text-slate-300">
                    {friend.bio}
                  </p>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </SectionPanel>
  </div>
</Layout>
